@model IEnumerable<NorthwindApp.Models.Order>

@{
    ViewData["Title"] = "Órdenes";
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 0);
    var searchString = (string?)ViewData["SearchString"];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Órdenes</h1>
    <a asp-action="Create" class="btn btn-primary">Crear nueva</a>
</div>

<form method="get" class="d-flex mb-3">
    <div class="input-group search-box">
        <input type="text" name="searchString" class="form-control" placeholder="Buscar órdenes (ID, cliente, destino)..." value="@searchString" />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(searchString))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Req.</th>
                <th>Destinatario</th>
                <th>Ciudad</th>
                <th>País</th>
                <th>Flete</th>
                <th>Cliente</th>
                <th>Empleado</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@item.OrderId</td>
                <td>@Html.DisplayFor(modelItem => item.OrderDate)</td>
                <td>@Html.DisplayFor(modelItem => item.RequiredDate)</td>
                <td>@Html.DisplayFor(modelItem => item.ShipName)</td>
                <td>@Html.DisplayFor(modelItem => item.ShipCity)</td>
                <td>@Html.DisplayFor(modelItem => item.ShipCountry)</td>
                <td>@Html.DisplayFor(modelItem => item.Freight)</td>
                <td>@Html.DisplayFor(modelItem => item.Customer.CustomerId)</td>
                <td>@Html.DisplayFor(modelItem => item.Employee.EmployeeId)</td>
                <td><span class="badge bg-success">Activo</span></td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    var start = Math.Max(1, currentPage - 2);
    var end = Math.Min(totalPages, currentPage + 2);
    <nav aria-label="Páginas de órdenes">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchString="@searchString">«</a>
            </li>
            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-searchString="@searchString">1</a>
                </li>
                if (start > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }
            @for (var i = start; i <= end; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchString="@searchString">@i</a>
                </li>
            }
            @if (end < totalPages)
            {
                if (end < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <a class="page-link" asp-action="Index" asp-route-page="@totalPages" asp-route-searchString="@searchString">@totalPages</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchString="@searchString">»</a>
            </li>
        </ul>
    </nav>
}
