@model NorthwindApp.Models.Order
@{
    ViewData["Title"] = "Detalles de la orden";
    var total = Model.OrderDetails.Sum(od => od.Quantity * od.UnitPrice);
}

<h1>Orden #@Model.OrderId</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h4>Información de la orden</h4></div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Fecha de orden</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.OrderDate)</dd>
                    <dt class="col-sm-4">Fecha requerida</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.RequiredDate)</dd>
                    <dt class="col-sm-4">Fecha de envío</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.ShippedDate)</dd>
                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.Customer.CustomerId)</dd>
                    <dt class="col-sm-4">Empleado</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.Employee.EmployeeId)</dd>
                    <dt class="col-sm-4">Transportista</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(m => m.ShipViaNavigation.ShipperId)</dd>
                    <dt class="col-sm-4">Flete</dt>
                    <dd class="col-sm-8">$@(Model.Freight?.ToString("F2"))</dd>
                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8">@(Model.Discontinued == 0 ? "Activo" : "Descontinuado")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h4>Envío</h4></div>
            <div class="card-body">
                <p><strong>@Html.DisplayFor(m => m.ShipName)</strong></p>
                <p>@Html.DisplayFor(m => m.ShipAddress)</p>
                <p>@Html.DisplayFor(m => m.ShipCity)</p>
                <p>@Html.DisplayFor(m => m.ShipCountry)</p>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h4>Detalles de la orden (@Model.OrderDetails.Count artículos)</h4></div>
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Precio unitario</th>
                    <th>Cantidad</th>
                    <th>Descuento</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detail in Model.OrderDetails)
                {
                    <tr>
                        <td>@detail.Product?.ProductName</td>
                        <td>$@(detail.UnitPrice.ToString("F2"))</td>
                        <td>@detail.Quantity</td>
                        <td>@(detail.Discount.ToString("P0"))</td>
                        <td>$@((detail.Quantity * detail.UnitPrice * (1 - detail.Discount)).ToString("F2"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-end"><strong>Total:</strong></td>
                    <td><strong>$@(total.ToString("F2"))</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.OrderId" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver a órdenes</a>
</div>
