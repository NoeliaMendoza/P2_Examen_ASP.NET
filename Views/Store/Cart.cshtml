@model List<NorthwindApp.Models.CartItem>

@{
    ViewData["Title"] = "Carrito de compras";
    var total = Model.Sum(c => c.Subtotal);
}

<h1>Carrito de compras</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Tu carrito está vacío. <a asp-action="Index">Ver productos</a>
    </div>
}
else
{
    <form asp-action="UpdateCart" method="post">
        <table class="table">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Precio unitario</th>
                    <th>Cantidad</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>@Model[i].ProductName</td>
                        <td>@Model[i].UnitPrice.ToString("F2")</td>
                        <td>
                            <input type="number" name="quantities[@Model[i].ProductId]"
                                   value="@Model[i].Quantity" min="0" class="form-control" style="max-width:80px" />
                        </td>
                        <td>@Model[i].Subtotal.ToString("F2")</td>
                        <td>
                            <button type="submit" formaction="@Url.Action("RemoveFromCart")"
                                    formmethod="post" name="productId" value="@Model[i].ProductId"
                                    class="btn btn-sm btn-danger">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end"><strong>Total:</strong></td>
                    <td><strong>@total.ToString("F2")</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">Actualizar carrito</button>
            <a asp-action="Checkout" class="btn btn-success">Proceder al pago</a>
            <a asp-action="Index" class="btn btn-outline-primary">Seguir comprando</a>
        </div>
    </form>
}
