@model List<NorthwindApp.Models.CartItem>

@{
    ViewData["Title"] = "Finalizar compra";
    var total = Model.Sum(c => c.Subtotal);
}

<h1>Finalizar compra</h1>

@if (Model.Count == 0)
{
    <div class="alert alert-warning">Tu carrito está vacío.</div>
    <a asp-action="Index" class="btn btn-primary">Ver productos</a>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <h4>Información de envío</h4>
            <form asp-action="Checkout" method="post">
                <div class="mb-3">
                    <label class="form-label">Destinatario</label>
                    <input name="shipName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Dirección</label>
                    <input name="shipAddress" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ciudad</label>
                    <input name="shipCity" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">País</label>
                    <input name="shipCountry" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-success btn-lg">Confirmar compra - $@(total.ToString("F2"))</button>
            </form>
        </div>
        <div class="col-md-6">
            <h4>Resumen de la orden</h4>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cant.</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>$@(item.UnitPrice.ToString("F2"))</td>
                            <td>$@(item.Subtotal.ToString("F2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end"><strong>Total:</strong></td>
                        <td><strong>$@(total.ToString("F2"))</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}
