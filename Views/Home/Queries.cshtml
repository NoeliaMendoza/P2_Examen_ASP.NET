@model NorthwindApp.Models.QueryReportViewModel

@{
    ViewData["Title"] = "Consultas";
}

<h1>Consultas</h1>

<h2>1. 10 productos más caros</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MostExpensiveProducts)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category?.CategoryName</td>
                <td>@item.Supplier?.CompanyName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>

<h2>2. Productos que contienen "@Model.SearchWord"</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsContainingWord)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category?.CategoryName</td>
                <td>@item.Supplier?.CompanyName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>

<h2>3. 10 productos con categoría (Include)</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsWithCategory)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category?.CategoryName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>

<h2>4. 10 productos con proveedor (Include)</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Proveedor</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsWithSupplier)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Supplier?.CompanyName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>

<h2>5. Productos de la categoría @Model.CategoryFilter (Join)</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsByCategoryJoin)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.CategoryName</td>
            </tr>
        }
    </tbody>
</table>

<h2>6. Productos para proveedor @Model.SupplierName</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Proveedor</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsForSupplier)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Supplier?.CompanyName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>

<h2>7. 5 pedidos más recientes</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Id Pedido</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Empleado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.RecentOrders)
        {
            <tr>
                <td>@item.OrderId</td>
                <td>@item.OrderDate?.ToString("yyyy-MM-dd")</td>
                <td>@item.Customer?.CompanyName</td>
                <td>@item.Employee != null ? item.Employee.FirstName + " " + item.Employee.LastName : ""</td>
            </tr>
        }
    </tbody>
</table>

<h2>8. Productos que aparecen en pedidos</h2>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th>Precio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ProductsInOrders)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category?.CategoryName</td>
                <td>@item.Supplier?.CompanyName</td>
                <td>@item.UnitPrice</td>
            </tr>
        }
    </tbody>
</table>
