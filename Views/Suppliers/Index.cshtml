@model IEnumerable<NorthwindApp.Models.Supplier>

@{
    ViewData["Title"] = "Proveedores";
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 0);
    var searchString = (string?)ViewData["SearchString"];
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Proveedores</h1>
    <a asp-action="Create" class="btn btn-primary">Crear nuevo</a>
</div>

<form method="get" class="d-flex mb-3">
    <div class="input-group search-box">
        <input type="text" name="searchString" class="form-control" placeholder="Buscar proveedores..." value="@searchString" />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
        @if (!string.IsNullOrEmpty(searchString))
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Compañía</th>
                <th>Contacto</th>
                <th>Cargo</th>
                <th>Ciudad</th>
                <th>País</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.CompanyName)</td>
                <td>@Html.DisplayFor(modelItem => item.ContactName)</td>
                <td>@Html.DisplayFor(modelItem => item.ContactTitle)</td>
                <td>@Html.DisplayFor(modelItem => item.City)</td>
                <td>@Html.DisplayFor(modelItem => item.Country)</td>
                <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                <td><span class="badge bg-success">Activo</span></td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-primary">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.SupplierId" class="btn btn-sm btn-outline-danger">Eliminar</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav aria-label="Páginas de proveedores">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchString="@searchString">Anterior</a>
            </li>
            @for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
            {
                <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@pageNumber" asp-route-searchString="@searchString">@pageNumber</a>
                </li>
            }
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchString="@searchString">Siguiente</a>
            </li>
        </ul>
    </nav>
}
